@model List<VgcCollege.Domain.Entities.Branch>
@{
    ViewData["Title"] = "Branches";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">Branches</h1>
        <p class="text-muted">Manage college campuses and locations</p>
    </div>
    <a asp-action="CreateBranch" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add New Branch
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    @foreach (var branch in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                            <i class="bi bi-buildings text-primary fs-4"></i>
                        </div>
                        <span class="badge bg-secondary">@(branch.Courses?.Count ?? 0) Courses</span>
                    </div>
                    <h5 class="card-title fw-bold">@branch.Name</h5>
                    <p class="card-text text-muted small">
                        <i class="bi bi-geo-alt me-1"></i> @branch.Address
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pb-3">
                    <div class="btn-group w-100" role="group">
                        <a asp-action="BranchDetails" asp-route-id="@branch.Id"
                           class="btn btn-outline-info">
                            <i class="bi bi-eye me-1"></i> View
                        </a>
                        <a asp-action="EditBranch" asp-route-id="@branch.Id"
                           class="btn btn-outline-warning">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                        <a asp-action="DeleteBranch" asp-route-id="@branch.Id"
                           class="btn btn-outline-danger">
                            <i class="bi bi-trash me-1"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-buildings fs-1 text-muted"></i>
        <h5 class="text-muted mt-3">No branches found</h5>
        <p class="text-muted">Click "Add New Branch" to create your first campus.</p>
    </div>
}
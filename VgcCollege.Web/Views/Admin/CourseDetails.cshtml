@model VgcCollege.Domain.Entities.Course
@{
    ViewData["Title"] = $"Course Details - {Model.Name}";
    var enrolledStudents = ViewBag.EnrolledStudents as List<VgcCollege.Domain.Entities.StudentProfile>;
    var facultyTeachers = ViewBag.FacultyTeachers as List<VgcCollege.Domain.Entities.FacultyProfile>;
}

<style>
    .student-card {
        transition: all 0.2s ease;
        border-radius: 12px;
    }

        .student-card:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
        }

    .faculty-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">@Model.Name</h1>
        <p class="text-muted">Course Details</p>
    </div>
    <div>
        <a asp-action="EditCourse" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Courses" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Course Information -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Course Information</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block">
                        <i class="bi bi-book text-primary fs-1"></i>
                    </div>
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Branch</dt>
                    <dd class="col-sm-7">
                        <a asp-action="BranchDetails" asp-route-id="@Model.BranchId" class="text-decoration-none">
                            <i class="bi bi-building me-1"></i>@Model.Branch?.Name
                        </a>
                    </dd>
                    <dt class="col-sm-5">Start Date</dt>
                    <dd class="col-sm-7">@Model.StartDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5">End Date</dt>
                    <dd class="col-sm-7">@Model.EndDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5">Duration</dt>
                    <dd class="col-sm-7">@((Model.EndDate - Model.StartDate).Days) days</dd>
                    <dt class="col-sm-5">Enrolled</dt>
                    <dd class="col-sm-7"><span class="badge bg-primary">@(enrolledStudents?.Count ?? 0) students</span></dd>
                </dl>
            </div>
        </div>

        <!-- Teaching Faculty -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-info text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Teaching Faculty</h5>
            </div>
            <div class="card-body p-0">
                @if (facultyTeachers?.Any() == true)
                {
                    <div class="list-group list-group-flush">
                        @foreach (var faculty in facultyTeachers)
                        {
                            <a asp-action="FacultyDetails" asp-route-id="@faculty.Id" class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                                <div class="faculty-avatar">
                                    @(faculty.Name.Split(' ').Last().FirstOrDefault().ToString().ToUpper())
                                </div>
                                <div>
                                    <div class="fw-semibold">@faculty.Name</div>
                                    <small class="text-muted">@faculty.Email</small>
                                </div>
                                <i class="bi bi-chevron-right ms-auto text-muted"></i>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-person-badge text-muted fs-3"></i>
                        <p class="text-muted mb-0">No faculty assigned</p>
                        <small class="text-muted">Assign faculty to this course</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Enrolled Students -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-people me-2"></i>Enrolled Students (@(enrolledStudents?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (enrolledStudents?.Any() == true)
                {
                    <div class="row g-3">
                        @foreach (var student in enrolledStudents)
                        {
                            <div class="col-md-6">
                                <div class="student-card p-3 border rounded-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="fw-bold mb-0">@student.Name</h6>
                                            <small class="text-muted">@student.StudentNumber</small>
                                        </div>
                                        <span class="badge bg-success">Active</span>
                                    </div>
                                    <div class="d-flex gap-3 mt-2">
                                        <div class="d-flex align-items-center gap-1">
                                            <i class="bi bi-envelope text-muted small"></i>
                                            <small class="text-muted">@student.Email</small>
                                        </div>
                                        <div class="d-flex align-items-center gap-1">
                                            <i class="bi bi-telephone text-muted small"></i>
                                            <small class="text-muted">@student.Phone</small>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <a asp-action="StudentDetails" asp-route-id="@student.Id" class="btn btn-sm btn-outline-primary w-100">
                                            View Student Profile <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-people text-muted fs-1"></i>
                        <h5 class="text-muted mt-2">No students enrolled</h5>
                        <p class="text-muted small">This course has no active enrollments yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
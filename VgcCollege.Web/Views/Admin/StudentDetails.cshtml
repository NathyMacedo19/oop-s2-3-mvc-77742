@model VgcCollege.Domain.Entities.StudentProfile
@{
    ViewData["Title"] = $"Student Details - {Model.Name}";
    var enrolments = ViewBag.Enrolments as List<VgcCollege.Domain.Entities.CourseEnrolment>;
    var assignmentResults = ViewBag.AssignmentResults as List<VgcCollege.Domain.Entities.AssignmentResult>;
    var examResults = ViewBag.ExamResults as List<VgcCollege.Domain.Entities.ExamResult>;
}

<style>
    .course-card {
        transition: all 0.2s ease;
        border-radius: 12px;
    }

        .course-card:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
        }

    .result-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

        .result-badge.A {
            background-color: #10b981;
            color: white;
        }

        .result-badge.B {
            background-color: #3b82f6;
            color: white;
        }

        .result-badge.C {
            background-color: #f59e0b;
            color: white;
        }

        .result-badge.D {
            background-color: #ef4444;
            color: white;
        }

        .result-badge.F {
            background-color: #6b7280;
            color: white;
        }

    .student-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 40px;
        font-weight: bold;
        margin: 0 auto;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">@Model.Name</h1>
        <p class="text-muted">Student ID: @Model.StudentNumber</p>
    </div>
    <div>
        <a asp-action="EditStudent" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Students" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Personal Information -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Personal Information</h5>
            </div>
            <div class="card-body text-center">
                <div class="student-avatar mb-3">
                    @(Model.Name?.Split(' ').FirstOrDefault()?.FirstOrDefault().ToString().ToUpper() ?? "S")
                </div>
                <h5 class="fw-bold mb-1">@Model.Name</h5>
                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                    <i class="bi bi-envelope text-muted"></i>
                    <span>@Model.Email</span>
                </div>
                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                    <i class="bi bi-telephone text-muted"></i>
                    <span>@Model.Phone</span>
                </div>
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-calendar text-muted"></i>
                    <span>@Model.DateOfBirth.ToString("dd MMM yyyy")</span>
                </div>
                <hr />
                <div class="text-start">
                    <small class="text-muted">Address</small>
                    <p class="mb-0">@Model.Address</p>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-info text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Academic Summary</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 mb-3">
                        <div class="p-2 bg-light rounded-3">
                            <i class="bi bi-journal-bookmark-fill text-primary fs-3"></i>
                            <h3 class="mb-0 mt-1">@(enrolments?.Count ?? 0)</h3>
                            <small class="text-muted">Courses</small>
                        </div>
                    </div>
                    <div class="col-6 mb-3">
                        <div class="p-2 bg-light rounded-3">
                            <i class="bi bi-pencil-square text-success fs-3"></i>
                            <h3 class="mb-0 mt-1">@(assignmentResults?.Count ?? 0)</h3>
                            <small class="text-muted">Assignments</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-light rounded-3">
                            <i class="bi bi-trophy text-warning fs-3"></i>
                            <h3 class="mb-0 mt-1">@(examResults?.Count ?? 0)</h3>
                            <small class="text-muted">Exams</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-light rounded-3">
                            <i class="bi bi-star text-danger fs-3"></i>
                            @{
                                var avgScore = assignmentResults?.Any() == true
                                ? assignmentResults.Average(r => r.Score).ToString("F0")
                                : "0";
                            }
                            <h3 class="mb-0 mt-1">@avgScore%</h3>
                            <small class="text-muted">Average</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Enrolled Courses -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Enrolled Courses (@(enrolments?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (enrolments != null && enrolments.Any())
                {
                    <div class="row g-3">
                        @foreach (var enrolment in enrolments)
                        {
                            var attendancePercent = enrolment.AttendanceRecords != null && enrolment.AttendanceRecords.Any()
                            ? (enrolment.AttendanceRecords.Count(a => a.Present) * 100 / enrolment.AttendanceRecords.Count)
                            : 0;
                            <div class="col-md-6">
                                <div class="course-card p-3 border rounded-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="fw-bold mb-0">@enrolment.Course?.Name</h6>
                                            <small class="text-muted"><i class="bi bi-building me-1"></i>@enrolment.Course?.Branch?.Name</small>
                                        </div>
                                        <span class="badge @(enrolment.Status == "Active" ? "bg-success" : "bg-secondary")">@enrolment.Status</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-calendar-check text-success"></i>
                                            <small>@enrolment.EnrolDate.ToString("dd MMM yyyy")</small>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress" style="width: 60px; height: 4px;">
                                                <div class="progress-bar @(attendancePercent >= 75 ? "bg-success" : attendancePercent >= 50 ? "bg-warning" : "bg-danger")"
                                                     style="width: @attendancePercent%"></div>
                                            </div>
                                            <small>@attendancePercent%</small>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <a asp-action="CourseDetails" asp-route-id="@enrolment.CourseId" class="btn btn-sm btn-outline-primary w-100">
                                            View Course <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-journal-bookmark-fill text-muted fs-1"></i>
                        <h5 class="text-muted mt-2">No enrolled courses</h5>
                    </div>
                }
            </div>
        </div>

        <!-- Assignment Results -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-success text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Assignment Results (@(assignmentResults?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (assignmentResults != null && assignmentResults.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Assignment</th>
                                    <th>Score</th>
                                    <th>Feedback</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in assignmentResults)
                                {
                                    <tr>
                                        <td>@result.Assignment?.Course?.Name</td>
                                        <td>@result.Assignment?.Title</td>
                                        <td><span class="badge @(result.Score >= 70 ? "bg-success" : result.Score >= 50 ? "bg-warning" : "bg-danger")">@result.Score / @result.Assignment?.MaxScore</span></td>
                                        <td>@result.Feedback</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-pencil-square text-muted fs-1"></i>
                        <p class="text-muted mb-0">No assignment results recorded</p>
                    </div>
                }
            </div>
        </div>

        <!-- Exam Results -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-trophy me-2"></i>Exam Results (@(examResults?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (examResults != null && examResults.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Exam</th>
                                    <th>Score</th>
                                    <th>Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in examResults)
                                {
                                    <tr>
                                        <td>@result.Exam?.Course?.Name</td>
                                        <td>@result.Exam?.Title</td>
                                        <td>@result.Score / @result.Exam?.MaxScore</td>
                                        <td><span class="result-badge @result.Grade">@result.Grade</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-trophy text-muted fs-1"></i>
                        <p class="text-muted mb-0">No exam results recorded</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
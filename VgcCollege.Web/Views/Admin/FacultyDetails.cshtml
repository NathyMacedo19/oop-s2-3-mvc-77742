@model VgcCollege.Domain.Entities.FacultyProfile
@{
    ViewData["Title"] = $"Faculty Details - {Model.Name}";
    var assignedCourses = ViewBag.AssignedCourses as List<VgcCollege.Domain.Entities.Course>;
}

<style>
    .course-card {
        transition: all 0.2s ease;
        border-radius: 12px;
    }

        .course-card:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
        }

    .faculty-avatar-lg {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 32px;
        font-weight: bold;
        margin: 0 auto;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">@Model.Name</h1>
        <p class="text-muted">Faculty Member</p>
    </div>
    <div>
        <a asp-action="EditFaculty" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Faculty" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Contact Information -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Contact Information</h5>
            </div>
            <div class="card-body text-center">
                <div class="faculty-avatar-lg mb-3">
                    @(Model.Name.Split(' ').Last().FirstOrDefault().ToString().ToUpper())
                </div>
                <h5 class="fw-bold mb-1">@Model.Name</h5>
                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                    <i class="bi bi-envelope text-muted"></i>
                    <span>@Model.Email</span>
                </div>
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-telephone text-muted"></i>
                    <span>@Model.Phone</span>
                </div>
            </div>
        </div>

        <!-- Teaching Summary -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-info text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Teaching Summary</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <i class="bi bi-journal-bookmark-fill text-primary fs-2"></i>
                            <h3 class="mb-0 mt-2">@(assignedCourses?.Count ?? 0)</h3>
                            <small class="text-muted">Assigned Courses</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <i class="bi bi-people text-success fs-2"></i>
                            @{
                                var totalStudents = assignedCourses?.Sum(c => c.Enrolments?.Count ?? 0) ?? 0;
                            }
                            <h3 class="mb-0 mt-2">@totalStudents</h3>
                            <small class="text-muted">Total Students</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Assigned Courses -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3 border-0">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Assigned Courses (@(assignedCourses?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (assignedCourses?.Any() == true)
                {
                    <div class="row g-3">
                        @foreach (var course in assignedCourses)
                        {
                            <div class="col-md-6">
                                <div class="course-card p-3 border rounded-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="fw-bold mb-0">@course.Name</h6>
                                            <small class="text-muted"><i class="bi bi-building me-1"></i>@course.Branch?.Name</small>
                                        </div>
                                        <span class="badge bg-secondary rounded-pill">@(course.Enrolments?.Count ?? 0) students</span>
                                    </div>
                                    <div class="d-flex gap-3 mt-2">
                                        <div class="d-flex align-items-center gap-1">
                                            <i class="bi bi-calendar-check text-success small"></i>
                                            <small>@course.StartDate.ToString("dd MMM yyyy")</small>
                                        </div>
                                        <div class="d-flex align-items-center gap-1">
                                            <i class="bi bi-calendar-x text-danger small"></i>
                                            <small>@course.EndDate.ToString("dd MMM yyyy")</small>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <a asp-action="CourseDetails" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary w-100">
                                            View Course Details <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-journal-bookmark-fill text-muted fs-1"></i>
                        <h5 class="text-muted mt-2">No courses assigned</h5>
                        <p class="text-muted small">This faculty member hasn't been assigned to any courses yet.</p>
                        <a asp-action="EditFaculty" asp-route-id="@Model.Id" class="btn btn-primary btn-sm mt-2">
                            <i class="bi bi-plus-circle me-1"></i> Assign Course
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@model VgcCollege.Domain.Entities.Branch
@{
    ViewData["Title"] = "Edit Branch";
    var facultyList = ViewBag.FacultyList as SelectList;
}

<div class="row">
    <div class="col-lg-8">
        <div class="page-header mb-4">
            <h1 class="display-6 fw-bold mb-1">Edit Branch</h1>
            <p class="text-muted">Update branch information and manage courses</p>
        </div>
    </div>
    <div class="col-lg-4 text-end">
        <a asp-action="Branches" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Branches
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Branch Information Card -->
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Branch Information</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditBranch" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Branch Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-semibold">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    @if (Model.Courses?.Any() == true)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            This branch has <strong>@Model.Courses.Count course(s)</strong>.
                        </div>
                    }

                    <hr />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save me-2"></i>Save Changes
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Courses Card -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Courses at @Model.Name</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Students</th>
                            <th>Faculty</th>
                            <th></th>
                    </thead>
                    <tbody>
                        @if (Model.Courses?.Any() == true)
                        {
                            @foreach (var course in Model.Courses.OrderBy(c => c.Name))
                            {
                                <tr>
                                    <td class="fw-semibold">@course.Name</td>
                                    <td>@course.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@course.EndDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge bg-secondary">@(course.Enrolments?.Count ?? 0)</span></td>
                                    <td><span class="badge bg-info">@(course.FacultyAssignments?.Count ?? 0)</span></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="CourseDetails" asp-route-id="@course.Id"
                                               class="btn btn-outline-info" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="EditCourse" asp-route-id="@course.Id"
                                               class="btn btn-outline-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-1"></i> No courses at this branch.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Create Course Card -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Course</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateCourseFromBranch" method="post">
                    <input type="hidden" name="branchId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Course Name</label>
                        <input type="text" name="courseName" class="form-control" required
                               placeholder="e.g., Software Development" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Start Date</label>
                            <input type="date" name="startDate" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">End Date</label>
                            <input type="date" name="endDate" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Assign Faculty <span class="text-danger">*</span></label>
                        <select name="selectedFaculty" class="form-select" multiple size="4" required>
                            @if (facultyList != null)
                            {
                                @foreach (var faculty in facultyList)
                                {
                                    <option value="@faculty.Value">@faculty.Text</option>
                                }
                            }
                        </select>
                        <small class="text-muted">Hold Ctrl to select multiple faculty members.</small>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-plus-circle me-2"></i>Create Course with Faculty
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
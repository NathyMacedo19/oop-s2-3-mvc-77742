@model List<VgcCollege.Domain.Entities.Exam>
@{
    ViewData["Title"] = "Exam Results";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-bold mb-1">Exam Results</h1>
    <p class="text-muted">Control when students can see their exam results</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Course</th>
                    <th>Exam Title</th>
                    <th>Date</th>
                    <th>Max Score</th>
                    <th>Status</th>
                    <th>Graded</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in Model)
                {
                    var isReleased = exam.ResultsReleased;
                    <tr>
                        <td class="fw-semibold">@exam.Course?.Name</td>
                        <td>@exam.Title</td>
                        <td>@exam.Date.ToString("dd MMM yyyy")</td>
                        <td>@exam.MaxScore</td>
                        <td>
                            @if (isReleased)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i> Released
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-lock me-1"></i> Hidden
                                </span>
                            }
                        </td>
                        <td><span class="badge bg-secondary">@(exam.Results?.Count ?? 0) students</span></td>
                        <td class="text-end">
                            <form asp-action="ToggleExamRelease" method="post" class="d-inline">
                                <input type="hidden" name="examId" value="@exam.Id" />
                                @if (isReleased)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-eye-slash me-1"></i> Hide
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-eye me-1"></i> Release
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-trophy fs-1 text-muted"></i>
        <h5 class="text-muted mt-3">No exams found</h5>
        <p class="text-muted">Exams will appear here once created in courses.</p>
    </div>
}
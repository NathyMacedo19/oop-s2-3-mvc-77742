@model VgcCollege.Domain.Entities.Course
@{
    ViewData["Title"] = "Delete Course";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="page-header mb-4">
            <h1 class="display-6 fw-bold mb-1">Delete Course</h1>
            <p class="text-danger">This action cannot be undone</p>
        </div>

        @if (Model.Enrolments?.Any() == true)
        {
            <div class="alert alert-warning mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Warning:</strong> This course has @Model.Enrolments.Count enrolled student(s).
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-book text-danger" style="font-size: 3rem;"></i>
                    <h4 class="mt-2">Are you sure?</h4>
                    <p class="text-muted">You are about to delete <strong>@Model.Name</strong></p>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4">Course Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Branch</dt>
                    <dd class="col-sm-8">@Model.Branch?.Name</dd>

                    <dt class="col-sm-4">Enrolled Students</dt>
                    <dd class="col-sm-8">@(Model.Enrolments?.Count ?? 0)</dd>
                </dl>

                <form asp-action="DeleteCourse">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-2"></i>Yes, Delete
                        </button>
                        <a asp-action="Courses" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
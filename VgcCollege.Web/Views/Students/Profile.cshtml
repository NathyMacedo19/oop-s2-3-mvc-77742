@model VgcCollege.Domain.Entities.StudentProfile
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-bold mb-1">My Profile</h1>
    <p class="text-muted">Your personal information</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Personal Information</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Student Number</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.StudentNumber</span></dd>

                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Email Address</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone Number</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4">Date of Birth</dt>
                    <dd class="col-sm-8">@Model.DateOfBirth.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Address</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <div class="mb-4">
            <i class="bi bi-shield-lock" style="font-size: 5rem; color: #dc3545;"></i>
        </div>
        <h1 class="display-4 text-danger fw-bold mb-3">Access Denied</h1>
        <p class="lead">You don't have permission to access this page.</p>
        <p class="text-muted">Your account role does not allow this action. Please contact an administrator if you think this is a mistake.</p>

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
                <i class="bi bi-house me-2"></i>Go to Home
            </a>
            @if (User.IsInRole("Student"))
            {
                <a asp-controller="Students" asp-action="Dashboard" class="btn btn-outline-secondary">
                    <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                </a>
            }
            else if (User.IsInRole("Faculty"))
            {
                <a asp-controller="Faculty" asp-action="Dashboard" class="btn btn-outline-secondary">
                    <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                </a>
            }
        </div>
    </div>
</div>
@model VgcCollege.Domain.Entities.Assignment
@{
    ViewData["Title"] = "Create Assignment";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="display-6 fw-bold mb-1">Create Assignment</h1>
                <p class="text-muted">Add a new assignment for your course</p>
            </div>
            <a asp-action="Assignments" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to Assignments
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CreateAssignment">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label fw-semibold">Course</label>
                        <select asp-for="CourseId" class="form-select" asp-items="ViewBag.MyCourses">
                            <option value="">-- Select Course --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Assignment Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., Console App Project, Final Report..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaxScore" class="form-label fw-semibold">Maximum Score</label>
                            <input asp-for="MaxScore" class="form-control" type="number" min="1" max="100" />
                            <span asp-validation-for="MaxScore" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DueDate" class="form-label fw-semibold">Due Date</label>
                            <input asp-for="DueDate" class="form-control" type="date" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>Create Assignment
                        </button>
                        <a asp-action="Assignments" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
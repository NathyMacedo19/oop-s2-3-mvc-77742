@{
    ViewData["Title"] = "Faculty Dashboard";
    var faculty = ViewBag.Faculty as VgcCollege.Domain.Entities.FacultyProfile;
    var myCourses = ViewBag.MyCourses as List<VgcCollege.Domain.Entities.Course>;
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-bold mb-1">Welcome back, @faculty?.Name!</h1>
    <p class="text-muted">Here's what's happening with your courses.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">My Courses</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.TotalCourses</h2>
                    </div>
                    <i class="bi bi-book fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">My Students</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.TotalStudents</h2>
                    </div>
                    <i class="bi bi-people fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">Pending Grading</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.PendingGrading</h2>
                    </div>
                    <i class="bi bi-clock fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>My Courses</h5>
            </div>
            <div class="list-group list-group-flush">
                @if (myCourses != null && myCourses.Any())
                {
                    @foreach (var course in myCourses)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0 fw-bold">@course.Name</h6>
                                <small class="text-muted">
                                    <i class="bi bi-building me-1"></i>@course.Branch?.Name
                                </small>
                            </div>
                            <a asp-action="MyStudents" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-primary">
                                View Students <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="list-group-item text-center text-muted py-4">
                        <i class="bi bi-info-circle me-1"></i> No courses assigned to you yet.
                        <br />
                        <small>Please contact an administrator to assign courses.</small>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0"><i class="bi bi-question-circle me-2"></i>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-action="MyStudents" class="btn btn-outline-primary py-2">
                        <i class="bi bi-people me-2"></i>View All Students
                    </a>
                    <a asp-action="Assignments" class="btn btn-outline-success py-2">
                        <i class="bi bi-pencil-square me-2"></i>Enter Grades
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
@using VgcCollege.Web.ViewModels
@{
    ViewData["Title"] = "My Students";
    var faculty = ViewBag.Faculty as VgcCollege.Domain.Entities.FacultyProfile;
    var courses = ViewBag.Courses as List<VgcCollege.Domain.Entities.Course>;
    var selectedCourse = ViewBag.SelectedCourse as VgcCollege.Domain.Entities.Course;
    var studentsWithAttendance = ViewBag.StudentsWithAttendance as List<StudentWithAttendanceViewModel>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">My Students</h1>
        <p class="text-muted">Students enrolled in your courses</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Course Selection Cards -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Select a Course</h5>
    </div>
    <div class="card-body">
        @if (courses != null && courses.Any())
        {
            <div class="row g-3">
                @foreach (var course in courses)
                {
                    <div class="col-md-4">
                        <a asp-action="MyStudents" asp-route-courseId="@course.Id" class="text-decoration-none">
                            <div class="card @(selectedCourse?.Id == course.Id ? "border-primary bg-primary bg-opacity-10" : "border-secondary") h-100">
                                <div class="card-body text-center">
                                    <i class="bi bi-book fs-2 @(selectedCourse?.Id == course.Id ? "text-primary" : "text-secondary")"></i>
                                    <h6 class="mt-2 mb-0">@course.Name</h6>
                                    <small class="text-muted">@course.Branch?.Name</small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info text-center mb-0">
                <i class="bi bi-info-circle me-2"></i> No courses assigned to you yet.
                <br />
                <small>Please contact an administrator to assign courses.</small>
            </div>
        }
    </div>
</div>

@if (selectedCourse != null)
{
    <!-- Students Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people me-2"></i>Students Enrolled in @selectedCourse.Name</h5>
                <div>
                    <a asp-action="MarkAttendance" asp-route-id="@selectedCourse.Id" class="btn btn-sm btn-outline-info me-2">
                        <i class="bi bi-calendar-check me-1"></i>Mark Attendance
                    </a>
                    <a asp-action="EnterGrades" asp-route-courseId="@selectedCourse.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil me-1"></i>Enter Grades
                    </a>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Student Number</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Attendance Rate</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (studentsWithAttendance != null && studentsWithAttendance.Any())
                    {
                        @foreach (var item in studentsWithAttendance)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@item.Student.StudentNumber</span>
                                </td>
                                <td class="fw-semibold">@item.Student.Name</td>
                                <td>@item.Student.Email</td>
                                <td>@item.Student.Phone</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress" style="width: 80px; height: 6px;">
                                            <div class="progress-bar @(item.AttendancePercent >= 75 ? "bg-success" : item.AttendancePercent >= 50 ? "bg-warning" : "bg-danger")"
                                                 style="width: @item.AttendancePercent%"></div>
                                        </div>
                                        <small>@item.AttendancePercent%</small>
                                    </div>
                                </td>
                                <td>
                                    <a asp-action="StudentDetails" asp-route-id="@item.Student.Id"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-eye me-1"></i>Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle me-1"></i> No students enrolled in this course.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Summary Footer -->
        @if (studentsWithAttendance != null && studentsWithAttendance.Any())
        {
            var totalStudents = studentsWithAttendance.Count;
            var avgAttendance = studentsWithAttendance.Average(s => s.AttendancePercent);

            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-6">
                        <strong>Total Students:</strong> @totalStudents
                    </div>
                    <div class="col-6">
                        <strong>Average Attendance:</strong> @avgAttendance%
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (courses != null && courses.Any())
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-2"></i> Select a course above to view enrolled students.
    </div>
}